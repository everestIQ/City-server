generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int             @id @default(autoincrement())
  firstName            String
  lastName             String
  otherName            String?
  email                String          @unique
  password             String
  phone                String
  address              String?
  dob                  DateTime
  accountType          AccountType?
  securityQuestion     String?
  securityAnswer       String?
  role                 Role            @default(CUSTOMER)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  lastLogin            DateTime?
  resetToken           String?
  resetTokenExpiry     DateTime?
  suspended            Boolean         @default(false)
  suspensionReason     String?
  suspendedAt          DateTime?
  emailVerified        Boolean         @default(false)               @@index([email])


  // ✅ Relations
  accounts             Account[]
  sentTransactions     Transaction[]   @relation("SentTransactions")
  receivedTransactions Transaction[]   @relation("ReceivedTransactions")
}

model Account {
  id            Int            @id @default(autoincrement())
  type          AccountType
  accountNumber String         @unique                                      @@index([accountNumber])
  balance       Float          @default(0)
  ledgerBalance Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  userId        Int

  transactions  Transaction[]
  currency      Currency         @default(USD)
  suspended     Boolean        @default(false)
  suspendedAt   DateTime?
  suspensionMessage String?
 
}

model Transaction {
  id                  Int               @id @default(autoincrement())
  amount              Float
  type                TransactionType
  status              TransactionStatus @default(SUCCESS)
  timestamp           DateTime          @default(now())
  description         String?
  recipientBank       String?
  beneficiaryName     String?
  beneficiaryAccount  String?
  swiftCode           String?
  iban                String?
  remark              String?
  purpose             String?
  method              String?
  account             Account           @relation(fields: [accountId], references: [id])
  accountId           Int
  
  referenceId         String            @unique @default(cuid())    @@index([referenceId])
  createdAt           DateTime          @default(now())             @@index([createdAt])

  sender              User?             @relation("SentTransactions", fields: [senderId], references: [id])
  senderId            Int?
  receiver            User?             @relation("ReceivedTransactions", fields: [receiverId], references: [id])
  receiverId          Int?             
  
  
}


enum Role {
  ADMIN
  CUSTOMER
}

enum AccountType {
  SAVINGS
  CURRENT
  BUSINESS
  CHECKING
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
  ADMIN_CREDIT
  ADMIN_DEBIT
  INTEREST
  CHARGEBACK
  REVERSAL
}

enum TransactionStatus {
    PENDING
    SUCCESS
    FAILED
    CANCELLED
}

enum Currency {
    USD
    EUR
    GBP
}